<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div class="admin">

        <aside class="admin-sidebar">
            <h2>Admin Panel</h2>

            <a href="/admin">Dashboard</a>
            <!-- <a href="/entries/all">All Journals</a> -->
            <a href="/auth/sign-out">Logout</a>
        </aside>


        <main class="admin-main">

            <h1>Dashboard</h1>

            <div class="admin-users">

                <div class="admin-header">
                    <h3>All Users</h3>
                </div>


                <% for (let oneUser of users) { %>

                    <% if (!oneUser.isDeleted && !oneUser.isAdmin) { %>

                        <div class="admin-user">

                            <span>
                                <%= oneUser.username %>
                            </span>

                            <form class="delete-form" action="/admin/<%= oneUser._id %>?_method=PUT" method="post">
                                <button class="delete-btn" type="submit">
                                    Delete
                                </button>
                            </form>

                        </div>

                    <% } %>

                <% } %>


            </div>

        </main>

    </div>

</body>
</html>